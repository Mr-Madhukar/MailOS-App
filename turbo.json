{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "DATABASE_URL_UNPOOLED",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "THREAD_ALLOW_DIRECT_SEND",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "CLIENT_URL",
    "BASE_URL",
    "API_INTERNAL_URL",
    "NODE_ENV",
    "BREVO_API_KEY",
    "EMAIL_FROM",
    "EMAIL_SENDER_NAME",
    "EMAIL_PROVIDER",
    "SEED_USER_EMAIL",
    "SEED_DEMO_PASSWORD",
    "VITEST",
    "OPENAPI_DOCS_SECRET",
    "PUBLIC_OPENAPI_DOCS",
    "PORT",
    "DEMO_LOGIN_ENABLED",
    "DEMO_USER_EMAIL",
    "DEMO_USER_PASSWORD",
    "GOOGLE_OAUTH_CLIENT_ID",
    "GOOGLE_OAUTH_CLIENT_SECRET",
    "GOOGLE_OAUTH_REDIRECT_URI",
    "HEALTH_CHECK_DATABASE",
    "CORSAIR_KEK",
    "CORSAIR_DEV_KEY",
    "CORSAIR_GMAIL_REDIRECT_URI",
    "CORSAIR_CALENDAR_REDIRECT_URI",
    "APP_URL",
    "LOGGER_LEVEL",
    "CORSAIR_WEBHOOK_SECRET",
    "REDIS_URL",
    "RATE_LIMIT_REQUIRE_REDIS",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "TURNSTILE_SECRET_KEY",
    "E2E_BASE_URL",
    "E2E_API_URL",
    "CI",
    "SKIP_ENV_VALIDATION",
    "OPENROUTER_API_KEY",
    "THREAD_E2E_MOCK_GMAIL",
    "THREAD_MCP_API_KEY",
    "WEBHOOKS_BASE_URL",
    "DISABLE_INTEGRATION_RENEWAL",
    "THREAD_MCP_USER_ID",
    "CORSAIR_GMAIL_TOPIC_ID",
    "THREAD_DEFAULT_TIMEZONE",
    "TZ",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_SERVICE_NAME",
    "E2E_GMAIL_AVAILABLE",
    "E2E_SESSION_COOKIE",
    "DOCS_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {},
    "db:migrate": {},
    "db:check": {},
    "db:seed": {},
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
