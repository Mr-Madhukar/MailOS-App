# Corsair credentials
CORSAIR_DEV_KEY=your_corsair_dev_key_here
CORSAIR_KEK=your_32_character_corsair_kek_here # e.g. kek_abc123xyz7890123456789012345

# Database URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/mailos

# GitHub Token (Optional)
GITHUB_TOKEN=your_github_token_here

# Next.js settings
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth Credentials (configured in Google Cloud Console)
GOOGLE_OAUTH_CLIENT_ID=your_google_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback

# JWT settings
JWT_ACCESS_SECRET=your_jwt_access_secret_here # Generate with `openssl rand -hex 32`

# AI Model settings (OpenRouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
